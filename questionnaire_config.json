{
  "meta": {
    "title": "Peptide Therapy Intake",
    "version": "1.0"
  },
  "sections": [
    {
      "id": "patient_info",
      "title": "Patient Information",
      "questions": [
        {
          "id": "patient_name",
          "text": "Full Name",
          "type": "text"
        },
        {
          "id": "patient_dob",
          "text": "Date of Birth",
          "type": "date"
        },
        {
          "id": "patient_sex",
          "text": "Biological Sex",
          "type": "single_choice",
          "options": [
            {
              "label": "Male",
              "value": "male"
            },
            {
              "label": "Female",
              "value": "female"
            }
          ]
        }
      ]
    },
    {
      "id": "product_selection",
      "title": "Product Selection",
      "questions": [
        {
          "id": "category_select",
          "text": "What is your category of interest?",
          "type": "multiselect",
          "options": [
            {
              "label": "Body Composition & Anti-Aging (Growth Hormone)",
              "value": "cat_gh",
              "next_module": "mod_gh_select"
            },
            {
              "label": "Repair & Recovery (BPC/TB-500/GHK)",
              "value": "cat_repair",
              "next_module": "mod_repair_select"
            },
            {
              "label": "Weight Loss (GLP-1s)",
              "value": "cat_weight",
              "next_module": "mod_weight_select"
            },
            {
              "label": "Sexual Health",
              "value": "cat_sex",
              "next_module": "mod_sex_select"
            },
            {
              "label": "Mitochondrial Health (MOTS-c, SS-31, SLU-PP-332)",
              "value": "cat_mito",
              "next_module": "mod_mito_select"
            },
            {
              "label": "Nutrient Injections (Glutathione, NAD+, B12)",
              "value": "cat_nutrient",
              "next_module": "mod_nutrient_select"
            },
            {
              "label": "Other / Unsure",
              "value": "other"
            }
          ]
        }
      ]
    },
    {
      "id": "common_screening",
      "title": "General Health Screening",
      "questions": [
        {
          "id": "prev_peptide_use",
          "text": "Have you previously received Peptides?",
          "type": "yes_no",
          "follow_up": {
            "yes": {
              "id": "prev_peptide_details",
              "text": "Which ones?",
              "type": "text"
            }
          }
        },
        {
          "id": "curr_peptide_use",
          "text": "Are you currently receiving Peptides elsewhere?",
          "type": "single_choice",
          "options": [
            {
              "label": "YES",
              "value": "yes"
            },
            {
              "label": "NO",
              "value": "no"
            }
          ],
          "follow_up": {
            "yes": {
              "text": "Please provide details:",
              "fields": [
                {
                  "id": "curr_peptide_names",
                  "label": "Peptide Name(s)",
                  "type": "text",
                  "placeholder": "e.g., BPC-157"
                },
                {
                  "id": "curr_peptide_form",
                  "label": "Form",
                  "type": "select",
                  "options": [
                    "Injectable",
                    "Oral",
                    "Troche",
                    "Cream",
                    "Nasal Spray",
                    "Other"
                  ]
                },
                {
                  "id": "curr_peptide_dose",
                  "label": "Current Dose",
                  "type": "text",
                  "placeholder": "e.g., 500mcg daily"
                }
              ]
            }
          }
        },
        {
          "id": "severe_allergy",
          "text": "Have you ever had a severe allergic reaction to Peptides?",
          "type": "yes_no",
          "flag": {
            "yes": "consult",
            "message": "History of severe allergic reaction to peptides requires physician review."
          },
          "follow_up": {
            "yes": {
              "id": "allergy_details",
              "text": "Which ones?",
              "type": "text"
            }
          }
        },
        {
          "id": "cancer_history",
          "text": "Do you currently have cancer or a history of cancer?",
          "type": "yes_no",
          "flag": {
            "yes": "stop",
            "message": "Active or history of cancer is a contraindication for peptide therapy."
          }
        },
        {
          "id": "pregnant_breastfeeding",
          "text": "Are you Pregnant or Breastfeeding?",
          "type": "yes_no",
          "flag": {
            "yes": "stop",
            "message": "Pregnancy or breastfeeding is a contraindication for peptide therapy."
          }
        },
        {
          "id": "professional_athlete",
          "text": "Are you a professional Athlete?",
          "type": "yes_no",
          "flag": {
            "yes": "stop",
            "message": "WADA-World Anti Doping Agency has banned peptide use."
          }
        },
        {
          "id": "severe_organ_disease",
          "text": "Have you been diagnosed with severe heart condition, uncontrolled high blood pressure, kidney disease, or liver disease?",
          "type": "yes_no",
          "flag": {
            "yes": "stop",
            "message": "Severe uncontrolled cardiovascular, liver, or kidney disease is a contraindication."
          }
        }
      ]
    }
  ],
